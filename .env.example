# All variables are optional — sensible defaults are baked in.
# Copy to .env for local development (`npm run dev` picks it up automatically).

PORT=4000
MONGODB_URI=mongodb://localhost:27017/crypto_dashboard

# How often the server polls CoinGecko. 30s = 2 upstream calls/min,
# comfortably inside the free tier's rate limit.
POLL_INTERVAL_MS=30000

# Data older than this is flagged as stale (3x the poll interval).
STALE_AFTER_MS=90000

COIN_COUNT=20

# How long price history is retained (Mongo TTL index), in seconds.
HISTORY_TTL_SECONDS=86400

# Optional. The public CoinGecko API works without a key. A free "demo" key
# raises the rate limit — get one at https://www.coingecko.com/en/api/pricing
# (Demo plan), then paste it here. Never commit a real key.
COINGECKO_API_KEY=
